# Server
PORT=3000
NODE_ENV=development

# Session (генерувати: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=change-me-32-byte-random-hex-string-required-in-production

# Security
BCRYPT_ROUNDS=10
LOGIN_RATE_WINDOW_MS=900000
LOGIN_RATE_MAX=5
API_RATE_WINDOW_MS=60000
API_RATE_MAX=120

# DB
DB_FILE=./data/heatpump.db
